*{
    margin:0;
    padding:0;
    box-sizing:border-box;
}


html{
    scroll-behavior:smooth;
}


body{

    background:#0b0b0b;
    color:#ffffff;
    font-family:'Poppins',sans-serif;
    overflow-x:hidden;

}


/* Loader */

#loader{

    position:fixed;
    width:100%;
    height:100vh;
    background:#0b0b0b;
    display:flex;
    justify-content:center;
    align-items:center;
    z-index:9999;

}


#loader h1{

    font-family:'Playfair Display',serif;
    color:#d4af37;
    font-size:45px;
    animation:pulse 1.5s infinite;

}


@keyframes pulse{

    50%{
        opacity:.4;
    }

}





/* Header */


header{

    position:fixed;
    top:0;
    left:0;
    width:100%;
    padding:22px 8%;
    display:flex;
    justify-content:space-between;
    align-items:center;
    background:rgba(0,0,0,.45);
    backdrop-filter:blur(15px);
    z-index:1000;

}



.logo{

    font-family:'Playfair Display',serif;
    font-size:32px;
    color:#d4af37;
    font-weight:bold;

}



nav a{

    color:white;
    text-decoration:none;
    margin-left:30px;
    font-size:15px;
    transition:.3s;

}


nav a:hover{

    color:#d4af37;

}



.menu-btn{

    display:none;
    font-size:28px;

}






/* Hero */


.hero{

    height:100vh;

    background:
    linear-gradient(
    rgba(0,0,0,.55),
    rgba(0,0,0,.75)
    ),
    url("assets/images/hero.jpg");

    background-size:cover;
    background-position:center;

    display:flex;
    align-items:center;
    justify-content:center;
    text-align:center;

}



.hero-content{

    animation:fadeUp 1.5s ease;

}



.hero h1{

    font-family:'Playfair Display',serif;
    font-size:70px;
    line-height:1.2;

}



.hero p{

    margin:25px 0;
    color:#ddd;
    font-size:20px;

}



.btn{

    display:inline-block;
    padding:15px 40px;
    background:#d4af37;
    color:#000;
    border-radius:50px;
    text-decoration:none;
    font-weight:600;
    border:none;
    cursor:pointer;
    transition:.4s;

}



.btn:hover{

    transform:translateY(-8px);
    box-shadow:0 10px 30px #d4af37;

}





/* Sections */


.section{

    padding:100px 8%;
    text-align:center;

}



.section h2{

    font-family:'Playfair Display',serif;
    font-size:45px;
    color:#d4af37;
    margin-bottom:50px;

}





/* Collection */


.collection-grid{

    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(280px,1fr));
    gap:35px;

}



.fashion-card{

    background:#151515;
    border-radius:20px;
    overflow:hidden;
    transition:.5s;

}



.fashion-card:hover{

    transform:translateY(-15px);

}



.fashion-card img{

    width:100%;
    height:400px;
    object-fit:cover;

}



.fashion-card h3{

    font-family:'Playfair Display',serif;
    font-size:25px;
    margin:20px;

}



.fashion-card p{

    color:#aaa;
    padding-bottom:20px;

}







/* About */


.about{

    background:#111;

}



.about p{

    max-width:800px;
    margin:auto;
    color:#ccc;
    line-height:2;
    font-size:18px;

}





/* Services */


.service-grid{

    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
    gap:30px;

}



.service-card{

    background:#151515;
    padding:40px;
    border-radius:20px;
    border:1px solid rgba(212,175,55,.2);
    transition:.4s;

}



.service-card:hover{

    border-color:#d4af37;
    transform:translateY(-10px);

}



.service-card h3{

    color:#d4af37;
    margin-bottom:15px;

}





/* Gallery */


.gallery{

    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
    gap:20px;

}



.gallery img{

    width:100%;
    height:350px;
    object-fit:cover;
    border-radius:20px;
    transition:.5s;

}



.gallery img:hover{

    transform:scale(1.05);

}





/* Reviews */


.review-box{

    max-width:700px;
    margin:25px auto;
    padding:35px;
    background:#151515;
    border-radius:20px;

}



.review-box p{

    color:#ddd;
    font-style:italic;

}


.review-box h4{

    color:#d4af37;
    margin-top:20px;

}






/* Appointment Form */


form{

    max-width:600px;
    margin:auto;
    display:flex;
    flex-direction:column;
    gap:20px;

}



input,
textarea{

    padding:15px;
    background:#151515;
    color:white;
    border:1px solid #333;
    border-radius:10px;
    outline:none;

}



textarea{

    height:150px;

}





/* Footer */


footer{

    padding:50px 20px;
    background:#050505;
    text-align:center;
    color:#999;

}



footer h3{

    color:#d4af37;
    font-family:'Playfair Display',serif;
    font-size:30px;

}





/* Animation */


@keyframes fadeUp{

    from{
        opacity:0;
        transform:translateY(40px);
    }

    to{
        opacity:1;
        transform:translateY(0);
    }

}






/* Mobile */


@media(max-width:768px){


header{

    padding:20px;

}


.logo{

    font-size:25px;

}


nav{

    display:none;

}


.menu-btn{

    display:block;

}



.hero h1{

    font-size:42px;

}



.hero p{

    font-size:16px;

}



.section{

    padding:70px 5%;

}



.section h2{

    font-size:35px;

}



.fashion-card img{

    height:320px;

}


}
