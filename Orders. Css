/* ==========================================
   VELORA ATELIER
   orders.css
   PART 1A
========================================== */


@import url('https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&family=Playfair+Display:wght@600;700&display=swap');


*{

    margin:0;

    padding:0;

    box-sizing:border-box;

}


:root{

    --gold:#D4AF37;

    --black:#0B0B0B;

    --dark:#151515;

    --white:#fff;

    --gray:#aaa;

    --border:rgba(255,255,255,.08);

}



body{

    background:var(--black);

    color:var(--white);

    font-family:'Poppins',sans-serif;

}



/* ===========================
        HEADER
=========================== */


.orders-header{

    position:fixed;

    top:0;

    left:0;

    width:100%;

    height:80px;

    padding:0 7%;

    display:flex;

    justify-content:space-between;

    align-items:center;

    background:rgba(0,0,0,.75);

    backdrop-filter:blur(15px);

    z-index:1000;

}



.logo{

    font-family:'Playfair Display',serif;

    font-size:32px;

    color:var(--gold);

}



.orders-header nav{

    display:flex;

    gap:30px;

}



.orders-header nav a{

    color:#fff;

    transition:.3s;

}



.orders-header nav a:hover,

.orders-header nav a.active{

    color:var(--gold);

}



/* ===========================
        HERO
=========================== */


.orders-hero{

    height:50vh;

    display:flex;

    justify-content:center;

    align-items:center;

    text-align:center;

    background:

    linear-gradient(
    rgba(0,0,0,.65),
    rgba(0,0,0,.75)
    ),

    url("assets/images/orders-banner.jpg")

    center/cover no-repeat;

}



.hero-content h1{

    font-family:'Playfair Display',serif;

    font-size:60px;

    margin-bottom:15px;

}



.hero-content p{

    color:#ddd;

    font-size:18px;

}



/* ===========================
        CONTAINER
=========================== */


.orders-container{

    width:min(1200px,92%);

    margin:70px auto;

}
/* ==========================================
   VELORA ATELIER
   orders.css
   PART 1B
========================================== */


/* ===========================
      ORDERS CARD
=========================== */

.orders-card{

    background:var(--dark);

    border:1px solid var(--border);

    border-radius:22px;

    padding:35px;

    box-shadow:
    0 15px 40px rgba(0,0,0,.35);

}



.orders-card h2{

    font-family:'Playfair Display',serif;

    color:var(--gold);

    font-size:34px;

    margin-bottom:30px;

}



/* ===========================
      ORDER CARD
=========================== */


.order-card{

    background:#111;

    border:1px solid rgba(255,255,255,.08);

    border-radius:18px;

    padding:25px;

    margin-bottom:25px;

    transition:.3s ease;

}



.order-card:hover{

    border-color:var(--gold);

    transform:translateY(-4px);

    box-shadow:

    0 15px 35px rgba(212,175,55,.12);

}



/* ===========================
      ORDER HEADER
=========================== */


.order-header{

    display:flex;

    justify-content:space-between;

    align-items:center;

    gap:20px;

    padding-bottom:20px;

    border-bottom:1px solid var(--border);

}



.order-header h3{

    font-family:'Playfair Display',serif;

    font-size:24px;

    color:#fff;

}



.order-header p{

    margin-top:8px;

    color:#aaa;

    font-size:14px;

}



/* ===========================
      STATUS BADGE BASE
=========================== */


.status-badge{

    padding:8px 18px;

    border-radius:30px;

    background:rgba(212,175,55,.15);

    color:var(--gold);

    font-size:14px;

    font-weight:600;

    white-space:nowrap;

}



/* ===========================
      ORDER PRODUCT AREA
=========================== */


.order-products{

    padding:25px 0;

}
/* ==========================================
   VELORA ATELIER
   orders.css
   PART 1C
========================================== */


/* ===========================
      PRODUCT ITEM
=========================== */


.product-item{

    display:flex;

    align-items:center;

    gap:20px;

    padding:18px 0;

    border-bottom:1px solid var(--border);

}



.product-item:last-child{

    border-bottom:none;

}



.product-item img{

    width:85px;

    height:85px;

    object-fit:cover;

    border-radius:14px;

    border:1px solid var(--border);

}



.product-info{

    flex:1;

}



.product-info h4{

    font-size:18px;

    margin-bottom:8px;

}



.product-info p{

    color:#aaa;

    font-size:14px;

}



.product-item strong{

    color:var(--gold);

    font-size:18px;

}





/* ===========================
      PRICE SECTION
=========================== */


.order-price{

    background:#171717;

    border-radius:15px;

    padding:20px;

    margin-top:15px;

}



.order-price div{

    display:flex;

    justify-content:space-between;

    padding:10px 0;

    color:#ccc;

}



.order-price strong{

    color:#fff;

}



.total-price{

    border-top:1px solid var(--border);

    margin-top:10px;

    padding-top:18px !important;

}



.total-price span{

    font-size:18px;

    font-weight:600;

}



.total-price strong{

    color:var(--gold);

    font-size:24px;

}



/* ===========================
      PAYMENT STATUS
=========================== */


.payment-status{

    display:flex;

    justify-content:space-between;

    margin-top:20px;

    color:#ccc;

}



.payment-status span{

    color:var(--gold);

    font-weight:600;

}



/* ===========================
      ACTION BUTTONS
=========================== */


.order-actions{

    display:flex;

    gap:15px;

    margin-top:25px;

}



.order-actions button{

    flex:1;

    padding:14px;

    border:none;

    border-radius:50px;

    cursor:pointer;

    font-weight:600;

    transition:.3s;

}



.view-order{

    background:var(--gold);

    color:#000;

}



.buy-again{

    background:#222;

    color:#fff;

    border:1px solid var(--border);

}



.order-actions button:hover{

    transform:translateY(-3px);

    box-shadow:

    0 10px 25px rgba(212,175,55,.2);

}
/* ==========================================
   VELORA ATELIER
   orders.css
   PART 2A
========================================== */


/* ===========================
      STATUS COLORS
=========================== */


.status-badge.delivered{

    background:rgba(46,204,113,.15);

    color:#2ecc71;

}



.status-badge.processing{

    background:rgba(241,196,15,.15);

    color:#f1c40f;

}



.status-badge.cancelled{

    background:rgba(231,76,60,.15);

    color:#e74c3c;

}



.paid{

    color:#2ecc71 !important;

}



.pending{

    color:#f1c40f !important;

}



/* ===========================
      EMPTY ORDERS
=========================== */


.empty-orders{

    text-align:center;

    padding:60px 20px;

    border:1px dashed rgba(255,255,255,.15);

    border-radius:18px;

}



.empty-orders h3{

    font-family:'Playfair Display',serif;

    font-size:30px;

    color:var(--gold);

    margin-bottom:15px;

}



.empty-orders p{

    color:#aaa;

    margin-bottom:25px;

}



.empty-orders a{

    display:inline-block;

    padding:14px 30px;

    border-radius:50px;

    background:var(--gold);

    color:#000;

    font-weight:600;

}



/* ===========================
      FOOTER
=========================== */


.orders-footer{

    text-align:center;

    padding:40px 20px;

    background:#080808;

    border-top:1px solid var(--border);

    color:#aaa;

}



.footer-logo{

    font-family:'Playfair Display',serif;

    font-size:28px;

    color:var(--gold);

    margin-bottom:10px;

}



.orders-footer p{

    margin:8px 0;

    font-size:14px;

}
/* ==========================================
   VELORA ATELIER
   orders.css
   PART 2B FINAL
========================================== */


/* ===========================
      CARD ANIMATION
=========================== */


.order-card{

    animation:slideUp .5s ease;

}



@keyframes slideUp{

    from{

        opacity:0;

        transform:translateY(25px);

    }

    to{

        opacity:1;

        transform:translateY(0);

    }

}



/* ===========================
      TABLET RESPONSIVE
=========================== */


@media(max-width:900px){


    .orders-card{

        padding:25px;

    }


    .order-header{

        align-items:flex-start;

        flex-direction:column;

    }


    .payment-status{

        flex-direction:column;

        gap:10px;

    }


}



/* ===========================
      MOBILE RESPONSIVE
=========================== */


@media(max-width:600px){


    .orders-header{

        height:auto;

        padding:18px 5%;

        flex-direction:column;

        gap:15px;

    }



    .orders-header nav{

        gap:18px;

        font-size:14px;

    }



    .logo{

        font-size:26px;

    }



    .orders-hero{

        height:40vh;

    }



    .hero-content h1{

        font-size:38px;

    }



    .orders-container{

        width:94%;

        margin-top:45px;

    }



    .orders-card{

        padding:18px;

        border-radius:16px;

    }



    .orders-card h2{

        font-size:26px;

    }



    .order-card{

        padding:18px;

    }



    .order-header h3{

        font-size:20px;

    }



    .product-item{

        align-items:flex-start;

        flex-direction:column;

    }



    .product-item img{

        width:100%;

        height:220px;

    }



    .order-actions{

        flex-direction:column;

    }



    .order-actions button{

        width:100%;

    }



}



/* ===========================
      SMALL MOBILE
=========================== */


@media(max-width:400px){


    .hero-content h1{

        font-size:32px;

    }


    .status-badge{

        font-size:12px;

        padding:7px 14px;

    }


    .total-price strong{

        font-size:20px;

    }


}
