// =============================
// Final Razorpay Success Handler
// =============================

function handleSuccessfulPayment(
response
){

    const order =
    getCurrentOrder();



    if(!order){

        alert(
        "Order information missing."
        );

        return;

    }



    if(
    checkDuplicatePayment(order)
    ){

        return;

    }



    completePayment(
        response,
        order
    );


}



// =============================
// Payment Button State
// =============================

function setButtonLoading(
state
){

    if(!placeOrderBtn)
    return;



    if(state){

        placeOrderBtn.classList.add(
        "loading"
        );

        placeOrderBtn.disabled=true;


    }else{


        placeOrderBtn.classList.remove(
        "loading"
        );

        placeOrderBtn.disabled=false;

    }

}



// =============================
// Safe Payment Start
// =============================

async function startPayment(){


    try{


        setButtonLoading(true);



        const loaded =
        await loadRazorpay();



        if(!loaded){

            throw new Error(
            "Razorpay not loaded"
            );

        }



        openRazorpay();



    }

    catch(error){


        console.log(
        error
        );


        alert(
        "Unable to start payment."
        );


    }

    finally{


        setButtonLoading(false);


    }


}



// =============================
// Cleanup Old Data
// =============================

function clearTemporaryPaymentData(){


    sessionStorage.removeItem(
    "paymentSession"
    );


}



// =============================
// Initialize Payment System
// =============================

document.addEventListener(
"DOMContentLoaded",
()=>{


    clearTemporaryPaymentData();


    console.log(
    "Velora Payment System Initialized ✔"
    );


});
