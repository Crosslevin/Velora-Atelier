// Payment Records + Order History
// ==========================================


// =============================
// Save Payment Record
// =============================

function savePaymentRecord(data){

    let payments =
    JSON.parse(
        localStorage.getItem("payments")
    )
    || [];


    payments.push(data);


    localStorage.setItem(
        "payments",
        JSON.stringify(payments)
    );

}



// =============================
// Create Payment Record
// =============================

function createPaymentRecord(
order,
paymentId
){

    return {

        orderId:
        order.id,

        paymentId:
        paymentId,

        amount:
        order.total,

        currency:
        "INR",

        customer:
        order.customer.name,

        status:
        "Success",

        method:
        order.payment,

        createdAt:
        new Date()
        .toISOString()

    };

}



// =============================
// Enhanced Payment Success
// =============================

function completePayment(
response,
order
){


    const paymentRecord =
    createPaymentRecord(
        order,
        response.razorpay_payment_id
    );



    savePaymentRecord(
        paymentRecord
    );



    order.paymentDetails =
    paymentRecord;



    savePaymentOrder(
        order
    );



    showPaymentSuccess(
        order.id
    );


}



// =============================
// Check Existing Payment
// =============================

function isPaymentCompleted(
orderId
){


    const payments =
    JSON.parse(
        localStorage.getItem("payments")
    )
    || [];



    return payments.some(
        payment =>
        payment.orderId === orderId
    );


}



// =============================
// Prevent Duplicate Payment
// =============================

function checkDuplicatePayment(
order
){


    if(
    isPaymentCompleted(order.id)
    ){

        alert(
        "Payment already completed."
        );

        return true;

    }


    return false;

}



console.log(
"Payment Records System Ready ✔"
