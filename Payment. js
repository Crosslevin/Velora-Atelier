// =============================
// Razorpay Configuration
// =============================

const razorpayKey =
"YOUR_RAZORPAY_KEY_ID";


// =============================
// Payment Button
// =============================

const placeOrderBtn =
document.getElementById(
"placeOrderBtn"
);


// =============================
// Get Last Order
// =============================

function getCurrentOrder(){

    return JSON.parse(
        localStorage.getItem(
        "lastOrder"
        )
    );

}



// =============================
// Payment Method
// =============================

function getPaymentMethod(){

    const payment =
    document.querySelector(
    'input[name="payment"]:checked'
    );


    return payment
    ? payment.value
    : "cod";

}



// =============================
// Check Razorpay Script
// =============================

function isRazorpayLoaded(){

    return typeof Razorpay !== "undefined";

}



// =============================
// Add Razorpay Script
// =============================

function loadRazorpay(){


return new Promise((resolve)=>{


    if(isRazorpayLoaded()){

        resolve(true);

        return;

    }


    const script =
    document.createElement(
    "script"
    );


    script.src =
    "https://checkout.razorpay.com/v1/checkout.js";


    script.onload=()=>{

        resolve(true);

    };


    script.onerror=()=>{

        resolve(false);

    };


    document.body.appendChild(
    script
    );


});


}



console.log(
"Payment Setup Loaded ✔"
);
// ==========================================
// VELORA ATELIER
// payment.js
// PART 1B
// Payment Trigger System
// ==========================================


// =============================
// Place Order Button Event
// =============================

if(placeOrderBtn){


placeOrderBtn.addEventListener(
"click",
async ()=>{


    const method =
    getPaymentMethod();



    // Cash On Delivery

    if(method === "cod"){


        processCOD();


        return;


    }



    // Online Payment

    if(
    method === "razorpay" ||
    method === "upi" ||
    method === "card"
    ){


        const loaded =
        await loadRazorpay();



        if(!loaded){

            alert(
            "Payment gateway failed to load."
            );

            return;

        }



        openRazorpay();


    }


});


}



// =============================
// COD Process
// =============================

function processCOD(){


    const order =
    getCurrentOrder();



    if(!order){

        alert(
        "Order data not found."
        );

        return;

    }



    order.paymentStatus =
    "COD - Pending";



    order.status =
    "Order Confirmed";



    localStorage.setItem(
    "lastOrder",
    JSON.stringify(order)
    );



    showPaymentSuccess(
    order.id
    );


}



// =============================
// Razorpay Checkout
// =============================

function openRazorpay(){


    const order =
    getCurrentOrder();



    if(!order){

        alert(
        "Order not found."
        );

        return;

    }



    const options = {


        key:
        razorpayKey,


        amount:
        order.total * 100,


        currency:
        "INR",


        name:
        "Velora Atelier",


        description:
        "Luxury Fashion Purchase",


        image:
        "assets/logo.png",



        prefill:{


            name:
            order.customer.name,


            email:
            order.customer.email,


            contact:
            order.customer.phone


        },



        theme:{


            color:
            "#D4AF37"


        },



        handler:function(response){


            paymentSuccess(
            response,
            order
            );


        },



        modal:{


            ondismiss:function(){


                console.log(
                "Payment Cancelled"
                );


            }


        }



    };



    const razorpay =
    new Razorpay(options);



    razorpay.open();


}



console.log(
"Payment Trigger Ready ✔"
);
