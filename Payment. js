// PART 1C
// Success + Failure Handling
// ==========================================


// =============================
// Payment Success
// =============================

function paymentSuccess(
response,
order
){


    order.paymentStatus =
    "Paid";


    order.paymentId =
    response.razorpay_payment_id;


    order.status =
    "Order Confirmed";



    savePaymentOrder(
    order
    );



    showPaymentSuccess(
    order.id
    );


}



// =============================
// Save Payment Order
// =============================

function savePaymentOrder(order){


    let orders =
    JSON.parse(
    localStorage.getItem("orders")
    )
    || [];



    const index =
    orders.findIndex(
    item=>item.id===order.id
    );



    if(index !== -1){

        orders[index]=order;

    }else{

        orders.push(order);

    }



    localStorage.setItem(
    "orders",
    JSON.stringify(orders)
    );



    localStorage.setItem(
    "lastOrder",
    JSON.stringify(order)
    );


}



// =============================
// Payment Failed
// =============================

function paymentFailed(error){


    console.log(
    "Payment Error:",
    error
    );


    alert(
    "Payment failed. Please try again."
    );


}



// =============================
// Universal Success UI
// =============================

function showPaymentSuccess(orderId){


    const modal =
    document.getElementById(
    "successModal"
    );


    const idText =
    document.getElementById(
    "orderId"
    );



    if(idText){

        idText.textContent =
        orderId;

    }



    if(modal){

        modal.classList.add(
        "active"
        );

    }


}



// =============================
// Razorpay Error Listener
// =============================

window.addEventListener(
"unhandledrejection",
(event)=>{

    paymentFailed(
    event.reason
    );

});



console.log(
"Payment Result Handler Ready ✔"
);
