/* ==========================================
   VELORA ATELIER
   checkout.css
   PART 1A
========================================== */

/* Google Font */
@import url('https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&family=Playfair+Display:wght@600;700&display=swap');

/* Reset */

*{
    margin:0;
    padding:0;
    box-sizing:border-box;
}

html{
    scroll-behavior:smooth;
}

body{

    font-family:'Poppins',sans-serif;

    background:#0b0b0b;

    color:#ffffff;

    overflow-x:hidden;

}

/* Variables */

:root{

    --gold:#D4AF37;

    --black:#0B0B0B;

    --dark:#151515;

    --white:#ffffff;

    --gray:#aaaaaa;

    --border:rgba(255,255,255,.08);

    --radius:18px;

}

/* Links */

a{

    text-decoration:none;

    color:inherit;

}

img{

    max-width:100%;

    display:block;

}

/* ===========================
        HEADER
=========================== */

.checkout-header{

    position:fixed;

    top:0;

    left:0;

    width:100%;

    height:80px;

    background:rgba(0,0,0,.75);

    backdrop-filter:blur(14px);

    display:flex;

    justify-content:space-between;

    align-items:center;

    padding:0 7%;

    z-index:999;

}

.logo{

    font-size:32px;

    font-family:'Playfair Display',serif;

    color:var(--gold);

    font-weight:700;

}

.checkout-header nav{

    display:flex;

    gap:30px;

}

.checkout-header nav a{

    color:#fff;

    transition:.3s;

}

.checkout-header nav a:hover,

.checkout-header nav a.active{

    color:var(--gold);

}

/* ===========================
        HERO
=========================== */

.checkout-hero{

    height:55vh;

    background:
    linear-gradient(rgba(0,0,0,.55),
    rgba(0,0,0,.65)),
    url("assets/images/checkout-banner.jpg")
    center/cover no-repeat;

    display:flex;

    justify-content:center;

    align-items:center;

    text-align:center;

    position:relative;

}

.hero-content{

    position:relative;

    z-index:2;

}

.hero-content h1{

    font-size:60px;

    font-family:'Playfair Display',serif;

    margin-bottom:18px;

}

.hero-content p{

    color:#dddddd;

    font-size:18px;

}

/* ===========================
      MAIN CONTAINER
=========================== */

.checkout-container{

    width:min(1200px,92%);

    margin:70px auto;

}
/* ==========================================
   VELORA ATELIER
   checkout.css
   PART 1B
========================================== */

/* ===========================
      CHECKOUT CARD
=========================== */

.checkout-card{

    background:var(--dark);

    border:1px solid var(--border);

    border-radius:var(--radius);

    padding:35px;

    margin-bottom:35px;

    box-shadow:0 10px 30px rgba(0,0,0,.25);

}

.checkout-card h2{

    font-family:'Playfair Display',serif;

    color:var(--gold);

    font-size:32px;

    margin-bottom:30px;

}

/* ===========================
      FORM
=========================== */

#checkoutForm{

    display:flex;

    flex-direction:column;

    gap:22px;

}

.input-group{

    display:flex;

    flex-direction:column;

}

.input-group label{

    margin-bottom:10px;

    color:var(--white);

    font-size:15px;

    font-weight:500;

}

/* ===========================
      INPUTS
=========================== */

.input-group input,

.input-group select,

.input-group textarea{

    width:100%;

    padding:15px 18px;

    background:#1c1c1c;

    border:1px solid transparent;

    border-radius:12px;

    color:#fff;

    font-size:15px;

    outline:none;

    transition:.3s;

}

.input-group input::placeholder,

.input-group textarea::placeholder{

    color:#888;

}

.input-group input:focus,

.input-group select:focus,

.input-group textarea:focus{

    border-color:var(--gold);

    box-shadow:0 0 0 3px rgba(212,175,55,.15);

}

.input-group textarea{

    resize:vertical;

    min-height:120px;

}

/* ===========================
      ADDRESS GRID
=========================== */

.input-row{

    display:grid;

    grid-template-columns:repeat(2,1fr);

    gap:20px;

}

/* ===========================
      SELECT
=========================== */

.input-group select{

    cursor:pointer;

}

/* ===========================
      FORM SPACING
=========================== */

.checkout-card form{

    margin-top:10px;

}

/* ===========================
      RESPONSIVE
=========================== */

@media(max-width:768px){

    .checkout-card{

        padding:24px;

    }

    .checkout-card h2{

        font-size:26px;

    }

    .input-row{

        grid-template-columns:1fr;

    }

    .input-group input,

    .input-group select,

    .input-group textarea{

        font-size:14px;

        padding:14px 16px;

    }

}

@media(max-width:480px){

    .checkout-card{

        padding:18px;

        border-radius:14px;

    }

    .checkout-card h2{

        font-size:22px;

    }

}
/* ==========================================
   VELORA ATELIER
   checkout.css
   PART 1C
========================================== */

/* ===========================
      DELIVERY & PAYMENT
=========================== */

.delivery-options,
.payment-options{

    display:grid;

    grid-template-columns:repeat(auto-fit,minmax(260px,1fr));

    gap:20px;

    margin-top:20px;

}

/* ===========================
      OPTION CARD
=========================== */

.option-card{

    display:flex;

    align-items:flex-start;

    gap:15px;

    padding:22px;

    background:#1a1a1a;

    border:1px solid var(--border);

    border-radius:16px;

    cursor:pointer;

    transition:.3s ease;

}

.option-card:hover{

    border-color:var(--gold);

    transform:translateY(-4px);

    box-shadow:0 12px 28px rgba(212,175,55,.15);

}

/* ===========================
      RADIO BUTTON
=========================== */

.option-card input[type="radio"]{

    margin-top:6px;

    accent-color:var(--gold);

    transform:scale(1.2);

}

/* ===========================
      TEXT
=========================== */

.option-card h3{

    font-size:20px;

    color:var(--gold);

    font-family:'Playfair Display',serif;

    margin-bottom:8px;

}

.option-card p{

    color:#c8c8c8;

    line-height:1.6;

    font-size:14px;

}

.option-card strong{

    display:block;

    margin-top:10px;

    color:#ffffff;

    font-size:16px;

}

/* ===========================
      SELECTED STATE
=========================== */

.option-card:has(input:checked){

    border-color:var(--gold);

    background:rgba(212,175,55,.08);

}

/* ===========================
      MOBILE
=========================== */

@media(max-width:768px){

    .delivery-options,
    .payment-options{

        grid-template-columns:1fr;

    }

    .option-card{

        padding:18px;

    }

    .option-card h3{

        font-size:18px;

    }

}
/* ==========================================
   VELORA ATELIER
   checkout.css
   PART 2A
========================================== */

/* ===========================
      ORDER SUMMARY
=========================== */

.order-summary{

    position:sticky;

    top:100px;

}

#orderItems{

    margin-bottom:25px;

}

.empty-order{

    text-align:center;

    padding:35px 20px;

    border:1px dashed rgba(255,255,255,.12);

    border-radius:14px;

}

.empty-order p{

    color:#aaaaaa;

}

/* ===========================
      SUMMARY ROWS
=========================== */

.summary-row{

    display:flex;

    justify-content:space-between;

    align-items:center;

    padding:14px 0;

    color:#dddddd;

}

.summary-row span:last-child{

    font-weight:600;

}

.summary-total{

    display:flex;

    justify-content:space-between;

    align-items:center;

    margin-top:18px;

    padding-top:18px;

    border-top:1px solid var(--border);

}

.summary-total strong{

    color:var(--gold);

    font-size:28px;

    font-family:'Playfair Display',serif;

}

/* ===========================
      COUPON SECTION
=========================== */

.coupon-box{

    display:flex;

    gap:15px;

    margin-top:18px;

}

.coupon-box input{

    flex:1;

    padding:15px 18px;

    border:none;

    outline:none;

    border-radius:12px;

    background:#1d1d1d;

    color:#ffffff;

}

.coupon-box button{

    padding:15px 28px;

    border:none;

    border-radius:12px;

    background:var(--gold);

    color:#000;

    font-weight:600;

    cursor:pointer;

    transition:.3s;

}

.coupon-box button:hover{

    transform:translateY(-2px);

    box-shadow:0 10px 25px rgba(212,175,55,.25);

}

.coupon-note{

    margin-top:15px;

    color:#aaaaaa;

    font-size:14px;

}

.coupon-note strong{

    color:var(--gold);

}

/* ===========================
      RESPONSIVE
=========================== */

@media(max-width:768px){

    .order-summary{

        position:static;

    }

    .coupon-box{

        flex-direction:column;

    }

    .coupon-box button{

        width:100%;

    }

    .summary-total strong{

        font-size:24px;

    }

}
/* ==========================================
   VELORA ATELIER
   checkout.css
   PART 2B
========================================== */

/* ===========================
      TERMS BOX
=========================== */

.terms-box{

    display:flex;

    align-items:flex-start;

    gap:12px;

    color:#cccccc;

    line-height:1.6;

    margin-bottom:25px;

    cursor:pointer;

}

.terms-box input{

    margin-top:5px;

    width:18px;

    height:18px;

    accent-color:var(--gold);

}


/* ===========================
      PLACE ORDER BUTTON
=========================== */

.hero-btn{

    display:inline-flex;

    justify-content:center;

    align-items:center;

    width:100%;

    padding:16px 30px;

    background:var(--gold);

    color:#000;

    border:none;

    border-radius:50px;

    font-weight:700;

    font-size:16px;

    cursor:pointer;

    transition:.3s;

}


.hero-btn:hover{

    transform:translateY(-3px);

    box-shadow:0 15px 30px rgba(212,175,55,.25);

}


.secondary-btn{

    background:#222;

    color:#fff;

}



/* ===========================
      SECURE CHECKOUT
=========================== */

.secure-checkout{

    text-align:center;

    margin-top:20px;

    color:#999;

    font-size:14px;

}



/* ===========================
      SUCCESS MODAL
=========================== */

.success-modal{

    position:fixed;

    inset:0;

    background:rgba(0,0,0,.85);

    display:none;

    justify-content:center;

    align-items:center;

    z-index:5000;

    padding:20px;

}


.success-content{

    width:100%;

    max-width:550px;

    background:#151515;

    border-radius:25px;

    padding:45px 35px;

    text-align:center;

    border:1px solid var(--gold);

    animation:popup .35s ease;

}


.success-icon{

    font-size:60px;

    margin-bottom:20px;

}


.success-content h2{

    color:var(--gold);

    font-family:'Playfair Display',serif;

    font-size:34px;

    margin-bottom:15px;

}


.success-content p{

    color:#cccccc;

    line-height:1.7;

    margin-bottom:12px;

}


.success-content strong{

    color:var(--gold);

}



/* ===========================
      SUCCESS BUTTONS
=========================== */

.success-buttons{

    display:flex;

    gap:15px;

    margin-top:30px;

}


.success-buttons .hero-btn{

    width:auto;

    flex:1;

}



/* ===========================
      ANIMATION
=========================== */

@keyframes popup{

    from{

        transform:scale(.8);

        opacity:0;

    }

    to{

        transform:scale(1);

        opacity:1;

    }

}



/* ===========================
      MOBILE
=========================== */

@media(max-width:600px){

    .success-content{

        padding:35px 20px;

    }


    .success-content h2{

        font-size:26px;

    }


    .success-buttons{

        flex-direction:column;

    }


    .success-buttons .hero-btn{

        width:100%;

    }

}
/* ==========================================
   VELORA ATELIER
   checkout.css
   PART 2C
========================================== */


/* ===========================
      CHECKOUT GRID LAYOUT
=========================== */

.checkout-container{

    display:grid;

    grid-template-columns:1.5fr .8fr;

    gap:35px;

    align-items:start;

}


/* ===========================
      SMOOTH ANIMATIONS
=========================== */

.checkout-card{

    animation:fadeUp .5s ease;

}


@keyframes fadeUp{

    from{

        opacity:0;

        transform:translateY(25px);

    }

    to{

        opacity:1;

        transform:translateY(0);

    }

}



/* ===========================
      BUTTON LOADING STATE
=========================== */

.hero-btn.loading{

    pointer-events:none;

    opacity:.7;

    position:relative;

}


.hero-btn.loading::after{

    content:"";

    width:18px;

    height:18px;

    border:3px solid #000;

    border-top-color:transparent;

    border-radius:50%;

    margin-left:10px;

    animation:spin .8s linear infinite;

}



@keyframes spin{

    to{

        transform:rotate(360deg);

    }

}



/* ===========================
      INPUT ERROR STYLE
=========================== */

.input-error{

    border-color:#ff4d4d !important;

}


.error-message{

    color:#ff6b6b;

    font-size:13px;

    margin-top:8px;

}



/* ===========================
      SUCCESS MODAL ACTIVE
=========================== */

.success-modal.active{

    display:flex;

}



/* ===========================
      SCROLLBAR
=========================== */

::-webkit-scrollbar{

    width:8px;

}


::-webkit-scrollbar-track{

    background:#111;

}


::-webkit-scrollbar-thumb{

    background:var(--gold);

    border-radius:20px;

}



/* ===========================
      TABLET
=========================== */

@media(max-width:992px){

    .checkout-container{

        grid-template-columns:1fr;

    }


    .order-summary{

        order:-1;

    }


}



/* ===========================
      MOBILE HEADER
=========================== */

@media(max-width:768px){

    .checkout-header{

        height:auto;

        padding:18px 5%;

        flex-direction:column;

        gap:15px;

    }


    .checkout-header nav{

        gap:18px;

        font-size:14px;

    }


    .logo{

        font-size:26px;

    }


    .checkout-hero{

        height:45vh;

    }


    .hero-content h1{

        font-size:38px;

    }


}



/* ===========================
      SMALL MOBILE
=========================== */

@media(max-width:480px){

    .checkout-container{

        width:94%;

        margin-top:45px;

    }


    .hero-content h1{

        font-size:32px;

    }


    .hero-content p{

        font-size:14px;

    }


    .summary-total strong{

        font-size:22px;

    }

}
.coupon-note{
    margin-top:12px;
    color:#aaa;
}

.coupon-note strong{
    color:var(--gold);
}
