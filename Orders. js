// PART 1C
// Order Actions
// ==========================================



// =============================
// View Order Details
// =============================

document.addEventListener(
"click",
(e)=>{


    if(
    e.target.classList.contains(
    "view-order"
    )
    ){


        const id =
        e.target.dataset.id;



        const order =
        orders.find(
        item=>item.id===id
        );



        if(order){


            alert(

            "Order ID: "
            + order.id
            +
            "\nTotal: ₹"
            + order.total
            +
            "\nStatus: "
            + order.status

            );


        }


    }



});




// =============================
// Buy Again
// =============================

document.addEventListener(
"click",
(e)=>{


    if(
    e.target.classList.contains(
    "buy-again"
    )
    ){


        const id =
        e.target.dataset.id;



        const order =
        orders.find(
        item=>item.id===id
        );



        if(!order)
        return;



        let cart =
        JSON.parse(
        localStorage.getItem("cart")
        )
        || [];



        order.products.forEach(
        product=>{


            const existing =
            cart.find(
            item=>
            item.name === product.name
            );



            if(existing){


                existing.quantity +=
                product.quantity;


            }

            else{


                cart.push(
                product
                );


            }


        });



        localStorage.setItem(

            "cart",

            JSON.stringify(cart)

        );



        alert(
        "Products added back to cart!"
        );



        window.location.href =
        "shop.html";



    }


});




// =============================
// Refresh Orders On Return
// =============================

window.addEventListener(
"storage",
()=>{


    orders =
    JSON.parse(
    localStorage.getItem("orders")
    )
    || [];



    renderOrders();


});



console.log(
"Order Actions Ready ✔"
);
