// PART 1A
// Cart Load + Order Render
// ==========================================


// =============================
// Get Cart Data
// =============================

let checkoutCart = JSON.parse(
    localStorage.getItem("cart")
) || [];


// =============================
// DOM Elements
// =============================

const orderItems =
document.getElementById("orderItems");

const subtotalPrice =
document.getElementById("subtotalPrice");

const shippingPrice =
document.getElementById("shippingPrice");

const grandTotal =
document.getElementById("grandTotal");


// =============================
// Render Order Items
// =============================

function renderOrderItems(){

    if(!orderItems) return;


    if(checkoutCart.length === 0){

        orderItems.innerHTML = `

        <div class="empty-order">

            <p>
            Your cart is empty.
            </p>

        </div>

        `;

        updateCheckoutTotal();

        return;

    }


    let html = "";


    checkoutCart.forEach(item=>{


        html += `

        <div class="order-item">


            <img 
            src="${item.image}"
            alt="${item.name}">


            <div>

                <h4>
                ${item.name}
                </h4>

                <p>
                Qty: ${item.quantity}
                </p>

                <strong>
                ₹${item.price * item.quantity}
                </strong>

            </div>


        </div>

        `;


    });


    orderItems.innerHTML = html;


    updateCheckoutTotal();

}



// =============================
// Calculate Subtotal
// =============================

function calculateSubtotal(){

    return checkoutCart.reduce(

    (total,item)=>{

        return total +
        (item.price * item.quantity);

    },0);

}



// =============================
// Initial Load
// =============================

renderOrderItems();


console.log(
"Checkout Cart Loaded ✔"
);
