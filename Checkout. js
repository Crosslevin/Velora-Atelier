// PART 1B
// Total Calculation + Shipping
// ==========================================


// =============================
// Delivery Elements
// =============================

const deliveryOptions =
document.querySelectorAll(
'input[name="delivery"]'
);


// =============================
// Calculate Shipping
// =============================

function calculateShipping(){

    const selectedDelivery =
    document.querySelector(
    'input[name="delivery"]:checked'
    );


    if(!selectedDelivery){

        return 0;

    }


    if(
    selectedDelivery.value === "express"
    ){

        return 199;

    }


    return 0;

}



// =============================
// Update Checkout Total
// =============================

function updateCheckoutTotal(){

    const subtotal =
    calculateSubtotal();


    const shipping =
    calculateShipping();


    const total =
    subtotal + shipping;



    if(subtotalPrice){

        subtotalPrice.textContent =
        `₹${subtotal.toLocaleString("en-IN")}`;

    }



    if(shippingPrice){

        shippingPrice.textContent =
        shipping === 0
        ? "Free"
        : `₹${shipping}`;

    }



    if(grandTotal){

        grandTotal.textContent =
        `₹${total.toLocaleString("en-IN")}`;

    }

}



// =============================
// Delivery Change Event
// =============================

deliveryOptions.forEach(option=>{


    option.addEventListener(
    "change",
    ()=>{

        updateCheckoutTotal();

    });


});



// Initial Calculation

updateCheckoutTotal();


console.log(
"Checkout Total System Ready ✔"
);
