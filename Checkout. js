// PART 1C
// Coupon System
// ==========================================


// =============================
// Coupon Elements
// =============================

const couponInput =
document.getElementById("couponCode");

const applyCouponBtn =
document.getElementById("applyCoupon");

const discountPrice =
document.getElementById("discountPrice");


// =============================
// Coupon Variables
// =============================

let discountAmount = 0;

let appliedCoupon = "";



// =============================
// Apply Coupon
// =============================

if(applyCouponBtn){

applyCouponBtn.addEventListener(
"click",
()=>{


    const code =
    couponInput.value
    .trim()
    .toUpperCase();



    if(code === "WELCOME10"){


        appliedCoupon = code;


        const subtotal =
        calculateSubtotal();



        discountAmount =
        Math.round(
        subtotal * 0.10
        );



        alert(
        "Coupon Applied! 10% Discount Added."
        );


    }

    else{


        discountAmount = 0;

        appliedCoupon = "";


        alert(
        "Invalid Coupon Code"
        );


    }



    updateDiscount();

    updateCheckoutTotal();


});

}



// =============================
// Update Discount Display
// =============================

function updateDiscount(){


    if(discountPrice){


        discountPrice.textContent =

        discountAmount > 0

        ? `-₹${discountAmount.toLocaleString("en-IN")}`

        : "₹0";


    }


}



// =============================
// Override Total Calculation
// =============================

const oldUpdateCheckoutTotal =
updateCheckoutTotal;


updateCheckoutTotal = function(){


    const subtotal =
    calculateSubtotal();



    const shipping =
    calculateShipping();



    const total =
    subtotal +
    shipping -
    discountAmount;



    if(subtotalPrice){

        subtotalPrice.textContent =
        `₹${subtotal.toLocaleString("en-IN")}`;

    }



    if(shippingPrice){

        shippingPrice.textContent =
        shipping === 0
        ? "Free"
        : `₹${shipping}`;

    }



    if(discountPrice){

        discountPrice.textContent =
        discountAmount > 0
        ? `-₹${discountAmount.toLocaleString("en-IN")}`
        : "₹0";

    }



    if(grandTotal){

        grandTotal.textContent =
        `₹${Math.max(total,0).toLocaleString("en-IN")}`;

    }


};



updateCheckoutTotal();


console.log(
"Coupon System Ready ✔"
);
