// PART 2C
// Success Modal + Final Setup
// ==========================================


// =============================
// Success Modal Elements
// =============================

const successModal =
document.getElementById(
"successModal"
);


const orderIdText =
document.getElementById(
"orderId"
);



// =============================
// Open Success Modal
// =============================

function openSuccessModal(orderId){


    if(orderIdText){

        orderIdText.textContent =
        orderId;

    }


    if(successModal){

        successModal.classList.add(
        "active"
        );

    }


    resetCheckoutForm();


}



// =============================
// Reset Form
// =============================

function resetCheckoutForm(){


    if(checkoutForm){

        checkoutForm.reset();

    }


    discountAmount=0;

    appliedCoupon="";


}



// =============================
// Close Modal On Outside Click
// =============================

if(successModal){


successModal.addEventListener(
"click",
(e)=>{


    if(
    e.target === successModal
    ){

        successModal.classList.remove(
        "active"
        );

    }


});


}



// =============================
// Back Button Protection
// =============================

window.addEventListener(
"pageshow",
()=>{


    checkoutCart =
    JSON.parse(
    localStorage.getItem("cart")
    )
    || [];


    renderOrderItems();


});



// =============================
// Final Initialize
// =============================

renderOrderItems();

updateCheckoutTotal();


console.log(
"Velora Checkout System Loaded Successfully ✔"
);
