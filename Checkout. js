// =============================
// Form Elements
// =============================

const checkoutForm =
document.getElementById("checkoutForm");


// =============================
// Inputs
// =============================

const fullName =
document.getElementById("fullName");

const email =
document.getElementById("email");

const phone =
document.getElementById("phone");

const pincode =
document.getElementById("pincode");

const acceptTerms =
document.getElementById("acceptTerms");



// =============================
// Error Message
// =============================

function showError(input,message){

    input.classList.add(
        "input-error"
    );


    let error =
    input.parentElement
    .querySelector(".error-message");


    if(!error){

        error =
        document.createElement("small");

        error.className =
        "error-message";

        input.parentElement
        .appendChild(error);

    }


    error.textContent =
    message;

}



function clearError(input){

    input.classList.remove(
        "input-error"
    );


    const error =
    input.parentElement
    .querySelector(".error-message");


    if(error){

        error.remove();

    }

}



// =============================
// Email Validation
// =============================

function validEmail(value){

return /^[^\s@]+@[^\s@]+\.[^\s@]+$/
.test(value);

}



// =============================
// Phone Validation
// =============================

function validPhone(value){

return /^[6-9]\d{9}$/
.test(value);

}



// =============================
// PIN Validation
// =============================

function validPin(value){

return /^\d{6}$/
.test(value);

}



// =============================
// Validate Form
// =============================

function validateForm(){


let valid = true;



if(fullName.value.trim().length < 3){

showError(
fullName,
"Enter a valid name"
);

valid=false;

}else{

clearError(fullName);

}



if(!validEmail(email.value)){

showError(
email,
"Enter valid email"
);

valid=false;

}else{

clearError(email);

}



if(!validPhone(phone.value)){

showError(
phone,
"Enter valid 10 digit phone number"
);

valid=false;

}else{

clearError(phone);

}



if(!validPin(pincode.value)){

showError(
pincode,
"Enter valid 6 digit PIN code"
);

valid=false;

}else{

clearError(pincode);

}



if(!acceptTerms.checked){

alert(
"Please accept Terms & Conditions"
);

valid=false;

}



return valid;

}



// =============================
// Remove Error While Typing
// =============================

[
fullName,
email,
phone,
pincode
].forEach(input=>{


if(input){

input.addEventListener(
"input",
()=>{

clearError(input);

});

}


});



console.log(
"Form Validation Ready ✔"
);
